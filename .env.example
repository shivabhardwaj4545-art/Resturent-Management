# ==========================================================
# QR Restaurant SaaS — Environment Variables
# Copy this file to .env and fill in all values
# ==========================================================

# ----- DATABASE -----
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/qr_restaurant_db?schema=public"

# ----- REDIS -----
# Redis connection URL for session caching and rate limiting
REDIS_URL="redis://localhost:6379"

# ----- JWT -----
# Secret key for signing JWT access tokens (min 64 chars, use random string)
JWT_ACCESS_SECRET="your-super-secret-access-key-min-64-chars-change-in-production"
# Secret key for signing JWT refresh tokens (different from access secret)
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-64-chars-change-in-production"
# Access token TTL (15 minutes)
JWT_ACCESS_EXPIRES_IN="15m"
# Refresh token TTL (7 days)
JWT_REFRESH_EXPIRES_IN="7d"

# ----- SERVER -----
# Port the Express server listens on
PORT=4000
# Node environment: development | production | test
NODE_ENV="development"
# Frontend URL for CORS whitelist
CLIENT_URL="http://localhost:3000"
# API URL used internally
API_URL="http://localhost:4000"

# ----- EMAIL (SMTP) -----
# SMTP provider host (e.g., smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST="smtp.gmail.com"
# SMTP port (587 for TLS, 465 for SSL)
SMTP_PORT=587
# SMTP auth user (your email address)
SMTP_USER="your-email@gmail.com"
# SMTP auth password (app password for Gmail)
SMTP_PASS="your-app-password"
# From name and email displayed in sent emails
SMTP_FROM_NAME="EZ- Restaurant"
SMTP_FROM_EMAIL="noreply@qrrestaurant.com"

# ----- GOOGLE OAUTH -----
# Google OAuth client credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# ----- CLOUDINARY -----
# Cloudinary account credentials for image uploads
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ----- RAZORPAY -----
# Razorpay API keys (from Razorpay Dashboard → Settings → API Keys)
RAZORPAY_KEY_ID="rzp_test_your_key_id"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
# Razorpay webhook secret (for verifying payment webhooks)
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# ----- GROQ AI -----
# Groq API key for product recommendations and chatbot
GROQ_API_KEY="gsk_your_groq_api_key"
# Groq model to use (llama3-8b-8192 is fast and cost-effective)
GROQ_MODEL="llama3-8b-8192"

# ----- GOOGLE GEMINI AI -----
# Gemini API key for coupon suggestions and demand forecasting
GEMINI_API_KEY="your-gemini-api-key"
# Gemini model to use
GEMINI_MODEL="gemini-1.5-flash"

# ----- SUPER ADMIN SEED -----
# Initial super admin credentials (used in seed.ts)
SUPER_ADMIN_EMAIL="admin@qrrestaurant.com"
SUPER_ADMIN_PASSWORD="Admin@123456"
SUPER_ADMIN_NAME="Platform Admin"

# ----- RATE LIMITING -----
# Max requests per window for general routes
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
# Stricter limits for auth routes
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ----- PLATFORM CONFIG -----
# Default platform commission rate (percentage, e.g., 5 = 5%)
DEFAULT_COMMISSION_RATE=5
# GST rate for restaurant orders (percentage)
GST_RATE=18
